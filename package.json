{
  "name": "openclaw-web-portal",
  "version": "1.0.0",
  "description": "Web-facing OpenClaw control panel with secure remote access",
  "type": "module",
  "main": "gateway.js",
  "scripts": {
    "dev:server": "node --watch gateway.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node gateway.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "control-panel",
    "tailscale"
  ],
  "author": "Jonathan Marsh",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "google-auth-library": "^8.8.0",
    "axios": "^1.4.0",
    "express-rate-limit": "^6.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
